# ─────────────────────────────────────────────────────────────────────────────
# Face Check-in — Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# Django core
SECRET_KEY=django-insecure-replace-me-with-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
# Timezone for Django admin and template rendering (IANA tz name, e.g. Asia/Bangkok)
TIME_ZONE=Asia/Bangkok

# Database (leave blank to use SQLite default)
# For PostgreSQL: postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL credentials (used by docker-compose postgres profile)
POSTGRES_USER=face
POSTGRES_PASSWORD=face
POSTGRES_DB=face_checkin

# Caddy domain (deprecated - use cloudflared instead)
# DOMAIN=localhost

# Cloudflare Tunnel (cloudflared)
# Get your tunnel token from Cloudflare Zero Trust dashboard
# https://dash.teams.cloudflare.com/
TUNNEL_TOKEN=

# File storage — Backblaze B2 (S3-compatible)
# Set USE_S3=True to enable; leave False for local media storage
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com

# Face matching
# Cosine similarity threshold (0.0–1.0). Higher = stricter matching.
FACE_MATCH_THRESHOLD=0.6
